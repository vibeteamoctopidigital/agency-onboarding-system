generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  AGENCY_OWNER
  TEAM_MEMBER
  SUB_ACCOUNT
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStage {
  NEW
  ACCEPTED
  WORKING
  PENDING
  REVIEW
  RESOLVED
}

enum SubAccountStatus {
  PENDING
  ACTIVE
  REJECTED
  BLOCKED
}

enum SocialOrderStatus {
  PROPOSED // created by the agency on the client's behalf — awaiting client approval
  SUBMITTED // created by the sub-account — awaiting agency acceptance
  ACCEPTED
  IN_PROGRESS
  DELIVERED // agency says done — awaiting client confirmation
  COMPLETED // client confirmed receipt
  CANCELLED
}

model Agency {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  ghlCompanyId       String?   @unique
  // AES-256-GCM ciphertext (v1:iv:tag:data) — never store the raw key
  ghlApiKeyEncrypted String?
  // Media storage: agency-level PITs cannot carry media scopes, so the owner
  // designates ONE sub-account (location) whose PIT (medias.write) hosts all
  // uploaded files in that location's GHL Media Library.
  ghlMediaLocationId   String?
  ghlMediaKeyEncrypted String?
  // Random 64-hex secret embedded in the owner's GHL menu link
  // (app.com/admin/{companyId}?key=…) — the companyId alone is public
  // knowledge and must never grant an admin session by itself.
  autoLoginSecret    String?   @unique
  connectedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  users         User[]
  subAccounts   SubAccount[]
  tickets       Ticket[]
  emailTemplates EmailTemplate[]
  auditLogs     AuditLog[]
  stageConfigs  StageConfig[]
  socialOrders  SocialOrder[]
}

model SubAccount {
  id               String           @id @default(cuid())
  agencyId         String
  ghlLocationId    String
  name             String
  contactEmail     String?
  businessEmail    String?
  personalInfos    Json?
  businessInfos    Json?
  status           SubAccountStatus @default(PENDING)
  isNewInCrm       Boolean          @default(true)
  rejectionComment String?
  requestedAt      DateTime         @default(now())
  decidedAt        DateTime?
  decidedById      String?
  // Portal login identity, created when the sub-account is approved
  userId           String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  agency    Agency @relation(fields: [agencyId], references: [id])
  decidedBy User?  @relation("SubAccountDecisions", fields: [decidedById], references: [id])
  user      User?  @relation("SubAccountIdentity", fields: [userId], references: [id])

  @@unique([agencyId, ghlLocationId])
  @@index([agencyId, status])
}

model User {
  id             String    @id @default(cuid())
  email          String?
  passwordHash   String?
  name           String
  initials       String
  role           UserRole
  locationId     String?
  skills         String    @default("")
  isAvailable    Boolean   @default(true)
  isDeleted      Boolean   @default(false)
  tempPassword   Boolean   @default(false)
  contactEmail   String?
  plan           String?
  agencyId       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  agency            Agency    @relation(fields: [agencyId], references: [id])
  assignedTickets   Ticket[]  @relation("Assignee")
  subAccountTickets Ticket[]  @relation("SubAccount")
  historyActions    TicketStageHistory[]
  attachments       Attachment[]
  notifications     Notification[]
  auditActions      AuditLog[]
  subAccountProfile SubAccount? @relation("SubAccountIdentity")
  subAccountDecisions SubAccount[] @relation("SubAccountDecisions")
  socialOrdersAsClient SocialOrder[] @relation("SocialOrderClient")
  socialOrdersCreated  SocialOrder[] @relation("SocialOrderCreator")
  socialOrderAssignments SocialOrderAssignee[] @relation("SocialOrderAssignments")
  socialOrderActions   SocialOrderUpdate[] @relation("SocialOrderActions")
  socialOrderUploads   SocialOrderFile[] @relation("SocialOrderUploads")
  socialOrderChats     SocialOrderMessage[] @relation("SocialOrderChats")

  @@unique([email, agencyId])
  @@index([agencyId])
  @@index([locationId])
  @@index([role])
}

model Ticket {
  id            String        @id @default(cuid())
  displayId     Int           @default(0)
  subject       String
  description   String
  priority      TicketPriority @default(MEDIUM)
  category      String
  stage         TicketStage   @default(NEW)
  assigneeId    String?
  subAccountId  String
  agencyId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assignee      User?     @relation("Assignee", fields: [assigneeId], references: [id])
  subAccount    User      @relation("SubAccount", fields: [subAccountId], references: [id])
  agency        Agency    @relation(fields: [agencyId], references: [id])
  history       TicketStageHistory[]
  attachments   Attachment[]
  notifications Notification[]

  @@index([agencyId])
  @@index([assigneeId])
  @@index([subAccountId])
  @@index([stage])
  @@index([priority])
  @@index([category])
}

model TicketStageHistory {
  id              String      @id @default(cuid())
  ticketId        String
  stage           TicketStage
  actorId         String
  comment         String
  isInternalNote  Boolean     @default(false)
  wasEmailed      Boolean     @default(true)
  createdAt       DateTime    @default(now())

  ticket  Ticket @relation(fields: [ticketId], references: [id])
  actor   User   @relation(fields: [actorId], references: [id])

  @@index([ticketId])
  @@index([createdAt])
}

model Attachment {
  id            String   @id @default(cuid())
  ticketId      String
  historyId     String?
  fileName      String
  fileUrl       String
  fileType      String
  fileSize      Int
  uploadedById  String
  createdAt     DateTime @default(now())

  ticket      Ticket @relation(fields: [ticketId], references: [id])
  uploadedBy  User   @relation(fields: [uploadedById], references: [id])

  @@index([ticketId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  ticketId  String?
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
}

model EmailTemplate {
  id        String      @id @default(cuid())
  agencyId  String
  stage     TicketStage
  subject   String
  body      String
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id])

  @@unique([agencyId, stage])
}

model AuditLog {
  id          String   @id @default(cuid())
  agencyId    String
  actorId     String
  action      String
  entityType  String
  entityId    String
  details     String?
  createdAt   DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id])
  actor  User   @relation(fields: [actorId], references: [id])

  @@index([agencyId, createdAt])
  @@index([actorId])
  @@index([entityType, entityId])
}

model SocialOrder {
  id           String            @id @default(cuid())
  displayId    Int
  title        String
  details      String
  // poster | logo | social-post | reel-video | banner | flyer | other
  orderType    String
  customType   String? // free text when orderType = "other"
  hashtags     String[] @default([])
  dueDate      DateTime?
  status       SocialOrderStatus @default(SUBMITTED)
  // Who created the order: the sub-account itself, or an owner proposing on its behalf
  createdById  String
  // Owner's message shown to the client on a PROPOSED order ("we discussed this in our meeting…")
  proposalNote String?
  subAccountId String
  agencyId     String
  acceptedAt   DateTime?
  deliveredAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  agency     Agency                @relation(fields: [agencyId], references: [id])
  subAccount User                  @relation("SocialOrderClient", fields: [subAccountId], references: [id])
  createdBy  User                  @relation("SocialOrderCreator", fields: [createdById], references: [id])
  assignees  SocialOrderAssignee[]
  updates    SocialOrderUpdate[]
  files      SocialOrderFile[]
  messages   SocialOrderMessage[]

  @@index([agencyId, status])
  @@index([subAccountId])
  @@index([agencyId, displayId])
}

model SocialOrderAssignee {
  id         String   @id @default(cuid())
  orderId    String
  userId     String
  assignedAt DateTime @default(now())

  order SocialOrder @relation(fields: [orderId], references: [id])
  user  User        @relation("SocialOrderAssignments", fields: [userId], references: [id])

  @@unique([orderId, userId])
  @@index([userId])
}

model SocialOrderUpdate {
  id        String            @id @default(cuid())
  orderId   String
  actorId   String
  status    SocialOrderStatus
  note      String
  createdAt DateTime          @default(now())

  order SocialOrder @relation(fields: [orderId], references: [id])
  actor User        @relation("SocialOrderActions", fields: [actorId], references: [id])

  @@index([orderId])
}

model SocialOrderFile {
  id           String   @id @default(cuid())
  orderId      String
  fileName     String
  fileUrl      String
  fileType     String
  fileSize     Int
  uploadedById String
  createdAt    DateTime @default(now())

  order      SocialOrder @relation(fields: [orderId], references: [id])
  uploadedBy User        @relation("SocialOrderUploads", fields: [uploadedById], references: [id])

  @@index([orderId])
}

// Chat is phase 2 — the table exists now so no migration is needed later.
model SocialOrderMessage {
  id        String    @id @default(cuid())
  orderId   String
  senderId  String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  order  SocialOrder @relation(fields: [orderId], references: [id])
  sender User        @relation("SocialOrderChats", fields: [senderId], references: [id])

  @@index([orderId, createdAt])
}

model StageConfig {
  id        String      @id @default(cuid())
  agencyId  String
  stageKey  TicketStage
  name      String
  color     String
  order     Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id])

  @@unique([agencyId, stageKey])
}
