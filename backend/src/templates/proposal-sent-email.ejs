<!doctype html>
<html>
<body style="margin:0;background:#f4f5f7;padding:24px;font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#1f2937">
  <div style="max-width:520px;margin:0 auto;background:#fff;border:1px solid #e5e7eb;border-radius:16px;overflow:hidden">
    <div style="padding:20px 28px;border-bottom:1px solid #f3f4f6;font-weight:700;font-size:15px;color:#111827">Octopi Support Desk</div>
    <div style="padding:24px 28px">
      <h1 style="font-size:18px;margin:0 0 12px;color:#111827">New Order Proposal</h1>
      <div style="font-size:14px;line-height:1.6;color:#374151">
        <p>Hi <%= clientName || 'there' %>,</p>
        <p>Your agency has proposed a new order for you: <strong><%= orderTitle %></strong>.</p>
        <% if (proposalNote) { %>
          <p style="background:#f9fafb;border:1px solid #f3f4f6;border-radius:10px;padding:12px 14px;margin:12px 0"><%= proposalNote %></p>
        <% } %>
        <p>Please review the details and approve the proposal when you are ready.</p>
      </div>
      <p style="margin:28px 0 8px">
        <a href="<%= appBaseUrl %>/client/dashboard" style="background:#111827;color:#fff;text-decoration:none;padding:11px 20px;border-radius:8px;font-size:14px;font-weight:600;display:inline-block">Review Proposal</a>
      </p>
    </div>
  </div>
  <p style="max-width:520px;margin:16px auto 0;font-size:11px;color:#9ca3af;text-align:center">This is an automated message from your agency's support desk.</p>
</body>
</html>
