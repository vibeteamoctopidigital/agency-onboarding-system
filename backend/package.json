{
	"name": "express-typescript-boilerplate",
	"version": "1.0.14",
	"description": "An Express boilerplate backend",
	"author": "Edwin Hernandez",
	"repository": "edwinhern/express-typescript-2024",
	"license": "MIT",
	"main": "dist/index.js",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "prisma generate && tsc && tsup",
		"dev": "prisma generate && tsx watch src/index.ts",
		"start": "node dist/index.js",
		"build:vercel": "prisma generate && tsup --entry.index src/vercel-app.ts --out-dir api --format esm --sourcemap false --clean false --no-dts",
		"start:dev": "node --import=tsx --watch src/index.ts",
		"start:prod": "node dist/index.js",
		"seed": "node --import=tsx prisma/seed.ts",
		"check": "biome check --write",
		"test": "vitest run",
		"test:cov": "vitest run --coverage"
	},
	"prisma": {
		"seed": "node --import=tsx prisma/seed.ts"
	},
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "7.3.4",
		"@libsql/client": "^0.17.4",
		"@prisma/adapter-libsql": "^7.8.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@upstash/redis": "^1.38.0",
		"axios": "^1.18.1",
		"bcryptjs": "^3.0.3",
		"bullmq": "^5.80.2",
		"cloudinary": "^2.10.0",
		"cors": "2.8.6",
		"dotenv": "17.3.1",
		"ejs": "^6.0.1",
		"express": "5.2.1",
		"express-rate-limit": "8.3.1",
		"helmet": "8.1.0",
		"http-status-codes": "2.3.0",
		"ioredis": "^5.11.1",
		"jsonwebtoken": "^9.0.3",
		"multer": "^2.2.0",
		"nodemailer": "^9.0.3",
		"pg": "^8.22.0",
		"pino": "9.14.0",
		"pino-http": "10.5.0",
		"resend": "^6.17.2",
		"swagger-ui-express": "5.0.1",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/bcryptjs": "^3.0.0",
		"@types/cors": "2.8.19",
		"@types/ejs": "^3.1.5",
		"@types/express": "5.0.3",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.2.0",
		"@types/nodemailer": "^8.0.1",
		"@types/supertest": "6.0.3",
		"@types/swagger-ui-express": "4.1.8",
		"@vitest/coverage-v8": "3.2.4",
		"pino-pretty": "13.1.3",
		"prisma": "^7.8.0",
		"supertest": "7.1.4",
		"tsup": "8.5.1",
		"tsx": "4.21.0",
		"typescript": "5.9.2",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "3.2.4"
	},
	"engines": {
		"node": ">=22"
	},
	"tsup": {
		"entry": [
			"src/index.ts"
		],
		"outDir": "dist",
		"format": [
			"esm",
			"cjs"
		],
		"target": "es2020",
		"sourcemap": true,
		"clean": true,
		"dts": true,
		"splitting": false,
		"skipNodeModulesBundle": true
	}
}
