# Environment Configuration
NODE_ENV="development" # Options: 'development', 'production'
PORT="8080"            # The port your server will listen on
HOST="localhost"       # Hostname for the server
CORS_ORIGIN="http://localhost:8080" # Allowed CORS origin, adjust as necessary

DATABASE_URL="postgresql://user:password@localhost:5432/agency_dashboard"

JWT_SECRET=""          # long random string
JWT_REFRESH_SECRET=""  # different long random string
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
JWT_SUB_ACCOUNT_REFRESH_EXPIRY="24h"

# 32-byte hex key for AES-256-GCM encryption of GHL API keys at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# GoHighLevel API (verified against https://marketplace.gohighlevel.com/docs)
GHL_API_BASE_URL="https://services.leadconnectorhq.com"
GHL_API_VERSION="2021-07-28"

# ── Phase 4: URLs ──────────────────────────────────────────────
# Public base URL of THIS backend (used to build links to locally-stored
# attachments). Defaults to http://HOST:PORT if unset.
PUBLIC_BASE_URL="http://localhost:8080"
# Base URL of the frontend (used for links inside emails). Defaults to CORS_ORIGIN.
APP_BASE_URL="http://localhost:3000"

# ── Phase 4: Email (SMTP via Nodemailer) ───────────────────────
# Fill these to send real email. Works with SendGrid, SES, Postmark, Gmail, or
# any SMTP host. If left blank, emails are logged to the console instead of sent.
#   SendGrid  → host smtp.sendgrid.net, port 587, user "apikey", pass <API key>
#   Postmark  → host smtp.postmarkapp.com, port 587, user+pass = server token
#   SES       → host email-smtp.<region>.amazonaws.com, port 587, SMTP creds
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"          # "true" only for port 465
EMAIL_FROM="Support Desk <support@youragency.com>"

# ── Phase 4: Attachment storage (Cloudinary) ───────────────────
# Fill CLOUDINARY_URL (from the Cloudinary dashboard) to store uploads in
# Cloudinary. If left blank, files are saved to ./uploads and served locally.
CLOUDINARY_URL=""
# ...or set these three individually instead of CLOUDINARY_URL:
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Max upload size per file, in megabytes.
MAX_UPLOAD_MB="10"



