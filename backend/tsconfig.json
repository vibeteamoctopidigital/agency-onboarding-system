{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"noEmit": true,
		"baseUrl": "./",
"noImplicitAny": false,
		"paths": {
			"@/*": ["src/*"]
		},
		"moduleResolution": "Node",
		"importsNotUsedAsValues": "remove",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["vitest/globals"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
